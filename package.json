{
  "name": "openshift-ui-tests-template",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "lint": "eslint playwright --color",
    "lint:fix": "npm run lint -- --fix",
    "test-playwright": "playwright test --config=playwright/playwright.config.ts",
    "test-playwright-debug": "playwright test --config=playwright/playwright.config.ts --debug",
    "test-playwright-headed": "playwright test --config=playwright/playwright.config.ts --headed",
    "test-playwright-report": "playwright show-report --config=playwright/playwright.config.ts",
    "test-playwright-ui": "playwright test --config=playwright/playwright.config.ts --ui"
  },
  "devDependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@playwright/test": "^1.56.1",
    "@types/node": "^16.11.12",
    "@typescript-eslint/eslint-plugin": "^5.14.0",
    "@typescript-eslint/parser": "^5.14.0",
    "allure-js-commons": "^3.4.1",
    "allure-playwright": "^3.4.1",
    "dotenv": "^16.0.0",
    "eslint": "^8.10.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-import-resolver-typescript": "^2.5.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "playwright": "^1.56.1",
    "prettier": "^2.5.1",
    "ts-node": "10.x",
    "typescript": "^4.5.5"
  }
}
